# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# URL pública do site (sitemap, links absolutos)
VITE_SITE_URL=https://ajudealguemonline.com.br

# Google AdSense (opcional — também pode configurar em Admin → Configurações)
# ID do editor no formato ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_CLIENT_ID=
# true | false (padrão: ativo se houver client id)
VITE_ADSENSE_ENABLED=true
# IDs dos blocos de anúncio criados no painel AdSense
VITE_ADSENSE_SLOT_HOME=
VITE_ADSENSE_SLOT_LIST=
VITE_ADSENSE_SLOT_CAMPAIGN=

# Google Analytics 4 (opcional)
# ID de medição no formato G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=
